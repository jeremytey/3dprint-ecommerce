generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  basePrice   Float
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  optionGroups OptionGroup[]
  orderItems   OrderItem[]
}

model OptionGroup {
  id        String @id @default(cuid())
  productId String
  label     String
  order     Int    @default(0)

  product      Product       @relation(fields: [productId], references: [id])
  optionValues OptionValue[]

  @@index([productId])
}

model OptionValue {
  id            String  @id @default(cuid())
  optionGroupId String
  label         String
  hex           String?
  priceModifier Float   @default(0)
  order         Int     @default(0)

  optionGroup OptionGroup @relation(fields: [optionGroupId], references: [id])

  @@index([optionGroupId])
}

model Order {
  id            String      @id @default(cuid())
  customerName  String
  customerPhone String
  totalAmount   Float
  status        OrderStatus @default(PENDING)
  whatsappSent  Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  items OrderItem[]
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PRINTING
  DONE
}

model OrderItem {
  id              String @id @default(cuid())
  orderId         String
  productId       String
  productName     String
  quantity        Int
  unitPrice       Float
  selectedOptions Json

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}